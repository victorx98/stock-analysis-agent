{
  "timeHorizons": [
    "1-3 months",
    "6-12 months",
    "3-5 years"
  ],
  "defaultHorizon": "6-12 months",
  "confidenceLevels": [
    "low",
    "medium",
    "high"
  ],
  "signalLabels": [
    "strong_buy_watch",
    "buy_watch",
    "hold_neutral",
    "sell_watch",
    "strong_sell_watch",
    "insufficient_evidence"
  ],
  "minimumEvidenceForDirectionalSignal": {
    "primarySourceCount": 1,
    "independentSourceCount": 3,
    "mustIncludeContraryEvidence": true,
    "mustIncludeInvalidationTriggers": true,
    "mustIncludeValuationAssessment": true,
    "mustIncludeLeadershipAssessment": true,
    "mustIncludeInsiderAndBuybackAssessment": true,
    "mustIncludePriorThesisReview": true,
    "mustIncludeEdgeAssessment": true
  },
  "priorThesisReviewPolicy": {
    "required": true,
    "accuracyLabels": [
      "accurate",
      "partly_accurate",
      "inaccurate",
      "too_early",
      "too_late",
      "still_untested",
      "baseline_no_prior_call"
    ],
    "minimumItemsToReview": [
      "prior_signal",
      "prior_confidence",
      "prior_valuation_classification",
      "prior_price_trend",
      "prior_invalidation_triggers",
      "prior_watch_items",
      "current_price_change",
      "current_fundamental_change",
      "lesson_applied"
    ]
  },
  "valuationPolicy": {
    "priority": "Prefer stocks with a conservative, source-backed case for material undervaluation, especially severe undervaluation with identifiable catalysts and manageable downside.",
    "classifications": [
      "severely_undervalued",
      "moderately_undervalued",
      "fairly_valued",
      "overvalued",
      "valuation_uncertain"
    ],
    "severeUndervaluationGuide": "Normally requires roughly 35% or more upside to conservative base-case value, survivable balance sheet risk, and a credible path for the market to close the gap.",
    "modelFamiliesByBusinessType": {
      "stable_profitable": ["free_cash_flow_dcf", "owner_earnings", "pe", "ev_ebit", "ev_ebitda"],
      "software_subscription": ["ev_revenue", "ev_gross_profit", "rule_of_40", "scenario_dcf"],
      "bank_lender": ["price_to_tangible_book", "price_to_book", "roe_rote", "credit_quality"],
      "insurer": ["price_to_book", "roe", "combined_ratio", "reserve_quality"],
      "reit": ["price_to_ffo", "price_to_affo", "nav", "cap_rates", "dividend_coverage"],
      "commodity_producer": ["nav", "ev_reserves", "ev_production", "cost_curve"],
      "cyclical_industrial": ["mid_cycle_earnings", "normalized_ev_ebitda", "replacement_value"],
      "consumer_retail": ["pe", "ev_ebitda", "same_store_sales", "unit_economics"],
      "marketplace_platform": ["ev_gross_profit", "take_rate", "gmv_quality", "cohort_economics"],
      "biotech_prerevenue": ["cash_runway", "dilution_risk", "probability_weighted_rnpv"],
      "holding_company": ["sum_of_the_parts", "nav_discount", "capital_allocation_record"],
      "distressed_turnaround": ["liquidation_value", "debt_maturity_wall", "cash_burn", "refinancing_risk"]
    }
  },
  "leadershipPolicy": {
    "classifications": [
      "leadership_edge",
      "adequate_leadership",
      "leadership_risk",
      "leadership_unknown"
    ],
    "requiredFields": [
      "ceoName",
      "founderStatus",
      "preCeoBackground",
      "priorTrackRecord",
      "managementStyle",
      "currentCompanyGoal",
      "executionPattern",
      "strategicClarity",
      "uniqueAdvantages",
      "redFlags"
    ]
  },
  "insiderAndBuybackPolicy": {
    "required": true,
    "defaultReviewWindow": "3-12 months",
    "requiredFields": [
      "reviewWindow",
      "managementTransactions",
      "buybackProgram",
      "thesisImpact",
      "missingInformation"
    ],
    "thesisImpactLabels": [
      "bullish",
      "bearish",
      "neutral",
      "mixed",
      "unknown"
    ]
  },
  "edgePolicy": {
    "required": true,
    "defaultPosture": "gated_edge",
    "artifact": "edge-lab.md",
    "hypothesisStatuses": [
      "unverified_lead",
      "partly_verified",
      "verified_edge",
      "disproved",
      "monitor_only"
    ],
    "edgeStatusLabels": [
      "none_found",
      "unverified_leads",
      "partly_verified",
      "verified_edge",
      "disproved"
    ],
    "signalInfluenceLabels": [
      "none",
      "watch_item",
      "confidence_adjustment",
      "signal_driver"
    ],
    "gates": {
      "tier3AloneMaxInfluence": "watch_item",
      "signalDriverRequires": "Primary evidence, directly observed public data, or multiple independent reputable sources.",
      "mustRecordDisprovedHypotheses": true
    },
    "requiredFields": [
      "consensusView",
      "highestConvictionVariantView",
      "edgeStatus",
      "signalInfluence",
      "contrarianTheses"
    ]
  },
  "technicalTrendDefaults": {
    "shortSmaDays": 20,
    "mediumSmaDays": 50,
    "longSmaDays": 200,
    "rsiDays": 14
  }
