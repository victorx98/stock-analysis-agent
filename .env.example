# Required by SEC fair access policy. Use a real contact email.
SEC_USER_AGENT="stock-analysis-framework/0.1 your-email@example.com"

# Optional. Used by tools/fetch-trusted-news.mjs.
NEWSAPI_API_KEY=""

# Optional. Used by news, market, and company-info collectors.
MASSIVE_API_KEY=""
MASSIVE_BASE_URL="https://api.massive.com"

# Optional. Used by news, market, and company-info collectors. If market data is absent, the tool attempts Stooq fallback.
ALPHA_VANTAGE_API_KEY=""

# Optional timezone used for run folders.
RUN_TIMEZONE="America/Los_Angeles"
